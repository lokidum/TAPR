# Database
DATABASE_URL=postgresql://tapr:tapr_dev@localhost:5432/tapr
TEST_DATABASE_URL=postgresql://tapr_test:testpassword@localhost:5433/tapr_test

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=your-jwt-secret-at-least-32-chars
JWT_ACCESS_SECRET=your-access-secret-32-chars-exactly!!
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=30d

# Stripe
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Twilio (optional for dev — leave empty to skip OTP SMS)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# AWS
AWS_REGION=ap-southeast-2
S3_ASSETS_BUCKET=
AWS_S3_BUCKET_NAME=
CLOUDFRONT_DOMAIN=

# Google Sign-In (optional)
GOOGLE_CLIENT_ID=

# DocuSign (optional — for partnership agreements)
DOCUSIGN_RSA_PRIVATE_KEY=
DOCUSIGN_INTEGRATION_KEY=
DOCUSIGN_USER_ID=
DOCUSIGN_ACCOUNT_ID=
DOCUSIGN_PARTNERSHIP_TEMPLATE_ID=
DOCUSIGN_HMAC_KEY=
DOCUSIGN_OAUTH_BASE_PATH=account-d.docusign.com
DOCUSIGN_BASE_PATH=https://demo.docusign.net/restapi

# Firebase (optional — for push notifications)
FIREBASE_SERVICE_ACCOUNT_JSON=

# CORS (comma-separated origins, empty for same-origin only)
ALLOWED_ORIGINS=

# Server
PORT=3000
NODE_ENV=development
